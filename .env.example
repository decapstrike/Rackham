DATABASE_URL=postgresql://learningforge:learningforge@localhost:55433/learningforge
OPENAI_API_KEY=
PORT=4000
NODE_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Local Docker Postgres defaults. Keep these aligned with docker-compose.yml.
POSTGRES_DB=learningforge
POSTGRES_USER=learningforge
POSTGRES_PASSWORD=learningforge

# Future AWS alpha configuration placeholders. Do not put secrets in Expo public vars.
AWS_REGION=us-east-1
AWS_PARAMETER_PREFIX=/learningforge/alpha
