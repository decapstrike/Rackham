DATABASE_URL=postgresql://mathforge:mathforge@localhost:5432/mathforge
OPENAI_API_KEY=
PORT=4000
NODE_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Local Docker Postgres defaults. Keep these aligned with docker-compose.yml.
POSTGRES_DB=mathforge
POSTGRES_USER=mathforge
POSTGRES_PASSWORD=mathforge

# Future AWS alpha configuration placeholders. Do not put secrets in Expo public vars.
AWS_REGION=us-east-1
AWS_PARAMETER_PREFIX=/mathforge/alpha
