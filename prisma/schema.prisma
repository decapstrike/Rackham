generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  parent
  child
  student
}

enum LearningContentStatus {
  active
  inactive
}

enum Theme {
  forge
  fantasy
  scifi
  sports
}

enum TutorTone {
  coach
  rival
  robot
  guide
}

enum QuestType {
  daily
  skill
  boss
  review
}

enum QuestStatus {
  not_started
  in_progress
  completed
  abandoned
}

enum AnswerFormat {
  multiple_choice
  numeric
  text
}

model User {
  id          String   @id
  role        UserRole
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students StudentProfile[] @relation("ParentStudents")
}

model StudentProfile {
  id               String    @id
  parentUserId     String?
  displayName      String
  gradeLevel       Int
  interests        String[]  @default([])
  avatarKey        String
  preferredTheme   Theme     @default(forge)
  tutorTone        TutorTone @default(coach)
  dailyGoalMinutes Int       @default(10)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  parent        User?                  @relation("ParentStudents", fields: [parentUserId], references: [id])
  progress      StudentSkillProgress[]
  quests        Quest[]
  attempts      ActivityAttempt[]
  inventory     RewardInventory?
  forgeUpgrades ForgeUpgrade[]

  @@index([parentUserId])
}

model Subject {
  id           String                @id
  name         String
  slug         String                @unique
  description  String
  status       LearningContentStatus @default(active)
  displayOrder Int

  domains SkillDomain[]
  skills  Skill[]
  quests  Quest[]
}

model SkillDomain {
  id           String                @id
  subjectId    String
  name         String
  slug         String                @unique
  description  String
  status       LearningContentStatus @default(active)
  displayOrder Int

  subject Subject @relation(fields: [subjectId], references: [id])
  skills  Skill[]

  @@index([subjectId])
}

model Skill {
  id           String                @id
  subjectId    String
  domainId     String
  name         String
  slug         String                @unique
  description  String
  gradeBand    String
  status       LearningContentStatus @default(active)
  displayOrder Int

  subject  Subject                @relation(fields: [subjectId], references: [id])
  domain   SkillDomain            @relation(fields: [domainId], references: [id])
  progress StudentSkillProgress[]
  attempts ActivityAttempt[]

  @@index([subjectId])
  @@index([domainId])
}

model StudentSkillProgress {
  id                String    @id
  studentProfileId  String
  skillId           String
  level             Int       @default(1)
  xp                Int       @default(0)
  masteryScore      Float     @default(0)
  attempts          Int       @default(0)
  correct           Int       @default(0)
  streakCorrect     Int       @default(0)
  streakIncorrect   Int       @default(0)
  currentDifficulty Int       @default(1)
  lastPracticedAt   DateTime?

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id])

  @@unique([studentProfileId, skillId])
}

model Quest {
  id               String      @id
  studentProfileId String
  subjectId        String
  questType        QuestType
  title            String
  flavorText       String?
  presentation     Json?
  focusSkillId     String
  status           QuestStatus @default(not_started)
  startedAt        DateTime?
  completedAt      DateTime?
  totalProblems    Int
  correctProblems  Int         @default(0)
  xpEarned         Int         @default(0)
  coinsEarned      Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  student  StudentProfile    @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  subject  Subject           @relation(fields: [subjectId], references: [id])
  attempts ActivityAttempt[]

  @@index([studentProfileId, status])
  @@index([subjectId])
}

model ActivityAttempt {
  id               String       @id
  questId          String
  studentProfileId String
  skillId          String
  activityType     String
  prompt           String
  answerFormat     AnswerFormat
  choices          Json?
  correctAnswer    String
  submittedAnswer  String?
  isCorrect        Boolean?
  difficulty       Int
  hintsUsed        Int          @default(0)
  timeSpentSeconds Int?
  explanation      String
  hintSequence     String[]
  metadata         Json
  createdAt        DateTime     @default(now())
  answeredAt       DateTime?

  quest   Quest          @relation(fields: [questId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id])

  @@index([questId])
  @@index([studentProfileId, answeredAt])
  @@index([skillId])
}

model RewardInventory {
  id               String    @id
  studentProfileId String    @unique
  coins            Int       @default(0)
  xp               Int       @default(0)
  level            Int       @default(1)
  unlockedItems    String[]  @default([])
  equippedItems    String[]  @default([])
  streakDays       Int       @default(0)
  lastCompletedAt  DateTime?
  updatedAt        DateTime  @updatedAt

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
}

model ForgeUpgrade {
  id               String   @id
  studentProfileId String
  upgradeKey       String
  upgradeName      String
  level            Int      @default(1)
  purchasedAt      DateTime @default(now())

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, upgradeKey])
}
